# Copia este archivo como .env y completa con los valores de Firebase Console
# Firebase Console → Tu proyecto → Configuración del proyecto → Tus apps → SDK config

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=   # opcional — solo si usas Google Analytics
